{# ============================================================
   contact-form.njk — Formulario de contacto único reutilizable

   Variables opcionales (definir con {% set %} antes del include):
   - withEmpresa  (bool)    Mostrar campo "empresa". Por defecto false.
   - submitText   (string)  Texto del botón enviar. Por defecto "ENVIAR".
   - submitClass  (string)  Clases CSS del botón. Por defecto "btn-primary btn--full".
   - modalBg      (string)  Color de fondo del modal. Por defecto "#ffffff".
   - sideContent  (html)    Bloque HTML a mostrar en la columna derecha,
                            encima del aviso legal. Útil para títulos
                            tipo "CONTACTA CON NOSOTROS".
   - sideClass    (string)  Clases CSS para la fila contenedora de sideContent.

   Envía a:
   - Netlify Forms (form-name="contactformulario")
   - /.netlify/functions/form-to-sheets  →  Google Sheets
============================================================ #}

<form name="contactformulario"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      id="contactForm"
      onsubmit="return validateForm()">

    {# ── Honeypot Netlify (campo invisible para bots) ── #}
    <p class="hidden" aria-hidden="true" style="position:absolute; left:-9999px;">
        <label>No rellenar si eres humano: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
    </p>

    {# ── Honeypot adicional propio (defensa en profundidad) ── #}
    <div style="display:none;">
        <input type="text" name="EmailSecurizado" value="" tabindex="-1" autocomplete="off">
    </div>

    {# ── Origen: URL de la página desde la que se envía el formulario.
         Se rellena en tiempo de build con la URL de Eleventy y se actualiza
         en cliente por si la página fuese servida desde otra ruta (alias). ── #}
    <input type="hidden" name="origen" id="origenForm" value="{{ page.url }}">

    <div class="row md:reverse">
        <div class="col-xs-12 col-md-6">
            <div class="row">
                <div class="col-xs-12 mb-16">
                    <div class="form-input-label-2">
                        <input id="nombre" type="text" placeholder="Nombre" class="input" name="nombre">
                        <label for="nombre">Nombre</label>
                    </div>
                </div>
                <div class="col-xs-12 mb-16">
                    <div class="form-input-label-2">
                        <input id="email" type="text" placeholder="Email" class="input" name="email" required
                               pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}">
                        <label for="email">Email</label>
                    </div>
                </div>
                <div class="col-xs-12 mb-16">
                    <div class="form-input-label-2">
                        <input id="telefono" type="text" placeholder="Teléfono" class="input" name="teléfono">
                        <label for="telefono">Teléfono</label>
                    </div>
                </div>
                {% if withEmpresa %}
                <div class="col-xs-12 mb-16">
                    <div class="form-input-label-2">
                        <input id="empresa" type="text" placeholder="Empresa" class="input" name="empresa">
                        <label for="empresa">Empresa</label>
                    </div>
                </div>
                {% endif %}
                <div class="col-xs-12 mb-32">
                    <div class="form-input-label-2">
                        <textarea id="textarea" placeholder="Tu mensaje" class="textarea" name="mensaje"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xs-12 col-md-6">
            {% if sideContent %}
            <div class="row {{ sideClass | default('') }}">
                <div class="col-xs-12">
                    {{ sideContent | safe }}
                </div>
            </div>
            {% endif %}

            <div class="mb-16">
                <label>
                    <input type="checkbox" name="politicas" required>
                    He leído y acepto los
                    <a href="/legal/politica-de-privacidad/" target="_blank" rel="noopener noreferrer" class="link-line">Términos y condiciones</a>
                    y entiendo la información acerca del uso de mis datos personales explicada en la
                    <a href="/legal/politica-de-privacidad/" target="_blank" rel="noopener noreferrer" class="link-line">Política de Privacidad</a>.
                </label>
            </div>
            <div class="mb-32 text-12-r">
                <p style="margin-bottom: 8px;">
                    Puede ejercer sus derechos de acceso, rectificación, cancelación y oposición,
                    así como solicitar la baja de sus datos, enviando un correo a
                    <a href="mailto:{{global_index.email}}?subject=Solicitud de baja de datos" class="link-line">{{global_index.email}}</a>
                </p>
                <p>
                    Para más información, consulte nuestra
                    <a href="/legal/politica-de-privacidad/" target="_blank" rel="noopener noreferrer" class="link-line">Política de Privacidad</a>
                    y nuestra <a href="/legal/cookies/" target="_blank" rel="noopener noreferrer" class="link-line">Política de Cookies</a>.
                </p>
            </div>

            <button aria-label="enviar email"
                    class="btn {{ submitClass | default('btn-primary btn--full') }}"
                    type="submit">
                {{ submitText | default('ENVIAR') }}
            </button>
        </div>
    </div>
</form>

{# ── Modal de confirmación ── #}
<div id="modalMensajeEnviado"
     style="display:none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: {{ modalBg | default('#ffffff') }}; z-index: 1000; align-items: center;">
    <button onclick="document.getElementById('modalMensajeEnviado').style.display='none'"
            class="btn btn-tertiary btn-modal" id="close-menu-modal" aria-label="Cerrar">
        <svg width="33" height="32" viewBox="0 0 33 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1.71973 30.6136L16.3333 16M16.3333 16L30.9468 1.38647M16.3333 16L30.9468 30.6136M16.3333 16L1.71973 1.38648"
                  stroke="#334552" stroke-width="2.61111" stroke-linecap="round"></path>
        </svg>
    </button>
    <div class="text-center"
         style="padding: 20px; max-width: 800px; margin: 100px auto; text-align: center; display: flex; flex-direction: column; align-items: center;">
        <div class="fluid-4-r mb-24">¡Gracias por contactar con nosotros!</div>
        <div class="h2 mb-24">En breves un comercial se pondrá en contacto contigo.</div>
        <button class="btn btn-primary btn--medium"
                onclick="document.getElementById('modalMensajeEnviado').style.display='none'">De acuerdo</button>
    </div>
</div>

{# ── Script (validación + envío a Netlify Forms + Google Sheets + GA4) ── #}
<script>
(function () {
    var form = document.getElementById('contactForm');
    if (!form) return;

    // Refuerza el origen con la URL real del navegador (build-time + runtime)
    var origenInput = document.getElementById('origenForm');
    if (origenInput) {
        origenInput.value = window.location.pathname + window.location.search;
    }

    window.validateForm = function () {
        var emailSecurizado = form.elements['EmailSecurizado'] ? form.elements['EmailSecurizado'].value : '';
        if (emailSecurizado) {
            return false;
        }
        var politicas = form.querySelector('input[name="politicas"]');
        if (politicas && !politicas.checked) {
            alert('Por favor, acepta los términos y condiciones.');
            return false;
        }
        return true;
    };

    form.addEventListener('submit', function (event) {
        event.preventDefault();
        if (!window.validateForm()) return;

        var formData = new FormData(form);
        formData.append('form-name', 'contactformulario');

        var jsonData = {};
        formData.forEach(function (value, key) { jsonData[key] = value; });

        var netlifyPromise = fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(formData).toString()
        });

        var sheetsPromise = fetch('/.netlify/functions/form-to-sheets', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(jsonData)
        });

        Promise.all([netlifyPromise, sheetsPromise]).then(function (responses) {
            if (responses[0].ok) {
                var origenValue = origenInput ? origenInput.value : window.location.pathname;
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'generate_lead',
                    'form_name': 'contactformulario',
                    'page_location': window.location.href,
                    'origen': origenValue
                });
                if (typeof gtag === 'function') {
                    gtag('event', 'generate_lead', {
                        'event_category': 'formulario',
                        'event_label': 'contactformulario',
                        'page_location': window.location.href,
                        'origen': origenValue
                    });
                }
                document.getElementById('modalMensajeEnviado').style.display = 'flex';
                form.reset();
            } else {
                alert('Hubo un error al enviar el mensaje.');
            }
        }).catch(function (error) {
            alert('Error al enviar el mensaje: ' + error.message);
        });
    });
})();
</script>
