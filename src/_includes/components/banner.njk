<!-- banner.njk — Envoltorio visual con formulario a la izquierda e información a la derecha.
     Usa el partial compartido components/contact-form.njk.
     NOTA: actualmente este componente NO está incluido en ninguna página. Se mantiene
     refactorizado por si se vuelve a usar en el futuro. -->
<div class="front-section">
    <section class="container-5">
        <div class="row ptr-120 pbr-120 md:reverse">
            <div class="col-xs-12 col-md-6 pt-16">

                {% set submitClass  = "btn-primary btn--full" %}
                {% set submitText   = global_index.banner_button %}
                {% set modalBg      = "#ffffff" %}
                {% set withEmpresa  = false %}

                {% include "components/contact-form.njk" %}

            </div>
            <div class="col-xs-12 col-md-6 mb-32">
                <div class="fluid-5-b mb-24">
                    {{global_index.banner_title}}
                </div>
                <div class="fluid-9-r mb-24">
                    {{global_index.banner_text}}
                </div>
                <div class="fluid-7-r mb-24">
                    {{global_index.banner_claim}}
                </div>
                <div class="mb-16 p-1"><a href="mailto:{{global_index.email}}">{{global_index.email}}</a></div>
                <div class="mb-16">T.{{global_index.telefono}}</div>
            </div>
        </div>
    </section>
</div>
