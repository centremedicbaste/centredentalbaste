<!DOCTYPE html>
<html lang="{{ global_index.lang }}">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <meta name="google-site-verification" content="{{ global_index.search_console }}" />
  <title>{{ metaTitle }} </title>
  <meta name="robots" content="{{ metaRobots | default('index, follow') }}" />
  <meta name="description"
    content="{{ metaDescription or eleventyComputed.metaDescription or global_index.seo_description or '' }}" />
  <meta name="keywords" content="{{ metaKeywords or eleventyComputed.metaKeywords or global_index.seo_description or '' }}" />
  <!-- Favicon y manifest -->
  <link rel="manifest" href="/site.webmanifest">
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="{{ global_index.title | default('Centre Dental Basté') }}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ metaTitle }}" />
  <meta property="og:description"
    content="{{ metaDescription or eleventyComputed.metaDescription or global_index.seo_description or '' }}" />
  <meta property="og:url" content="{{ global_index.url }}{{ (page.url | url) | lower }}" />
  <meta property="og:image" content="{{ global_index.url }}/assets/static/images/clinica-1.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ metaTitle }}" />
  <meta name="twitter:description"
    content="{{ metaDescription or eleventyComputed.metaDescription or global_index.seo_description or '' }}" />
  <meta name="twitter:image" content="{{ global_index.url }}/assets/static/images/clinica-1.jpg" />
  <link rel="icon" type="image/png" href="{{ global_index.url }}/assets/static/favicons/favicon-32x32.png" />
  <!-- Estilos CSS nuevos-->

  <style>
    :root {
  --c-gray: {{global_index.c_gray}};
  --c-primary: {{global_index.c_primary}};
  --c-secondary: {{global_index.c_secondary}};
  --bg-primary: {{global_index.bg_primary}};

  --c-bg-light: {{global_index.c_bg_light}};
  --c-bg-dark: {{global_index.c_bg_dark}};

  --bg-dark: {{global_index.bg_dark}};
  --bg-light: {{global_index.bg_light}};

  --btn-radius: {{global_index.btn_radius}};
  --padding-global: {{global_index.padding_global}};
  --btn-radius: {{global_index.btn_radius}};
  }
</style>



  <link rel="stylesheet" href="/assets/css/style.css" />
  <!-- SEO y Open Graph -->
  <link rel="canonical" href="{{ global_index.url }}{{ (page.url | url) | lower }}" />
  {% if page.url == '/' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["Dentist", "LocalBusiness"],
    "@id": "{{ global_index.url }}/#organization",
    "name": "{{ global_index.title }}",
    "url": "{{ global_index.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ global_index.url }}/assets/static/images/logos/logo.png"
    },
    "image": "{{ global_index.url }}/assets/static/images/clinica-1.jpg",
    "telephone": "{{ global_index.telefono }}",
    "email": "{{ global_index.email }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer Riera Basté, 18-20 bajos",
      "addressLocality": "Sant Boi de Llobregat",
      "addressRegion": "Barcelona",
      "postalCode": "08830",
      "addressCountry": "ES"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 41.346583,
      "longitude": 2.035658
    },
    "areaServed": {
      "@type": "City",
      "name": "Sant Boi de Llobregat"
    },
    "priceRange": "$$",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "20:00"
      }
    ],
    "sameAs": [
      "{{ global_index.social_instagram }}",
      "{{ global_index.social_linkedin }}",
      "{{ global_index.social_youtube }}"
    ],
    "description": "{{ global_index.seo_description }}",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Tratamientos dentales",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Implantología"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Ortodoncia"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Estética dental"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Periodoncia"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Endodoncia"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Odontopediatría"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Prótesis dentales"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Invisalign"}}
      ]
    }
  }
  </script>
  {% endif %}
  {% if page.url != '/' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "{{ global_index.url }}/"
      }{% if '/tratamientos/' in page.url and page.url != '/tratamientos/' %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Tratamientos",
        "item": "{{ global_index.url }}/tratamientos/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{{ metaTitle | replace(' | Centre Dental Basté', '') | replace(' - Centre Dental Basté', '') }}"
      }{% elif page.url == '/tratamientos/' %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Tratamientos"
      }{% elif '/blog/' in page.url and page.url != '/blog/' %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "{{ global_index.url }}/blog/"
      }{% elif page.url == '/blog/' %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog"
      }{% else %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ metaTitle | replace(' | Centre Dental Basté', '') | replace(' - Centre Dental Basté', '') }}"
      }{% endif %}
    ]
  }
  </script>
  {% endif %}
  <!-- Google Tag Manager -->
  {% if global_index.tag_manager %}
  <script>
    (function (w, d, s, l, i) {
      w[l] = w[l] || []; w[l].push({
        'gtm.start':
          new Date().getTime(), event: 'gtm.js'
      }); var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', '{{ global_index.tag_manager }}');
  </script>
  {% endif %}
  <!-- Google Analytics (gtag.js) -->
  {% if global_index.google_analytics %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ global_index.google_analytics }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('consent', 'default', { 'analytics_storage': 'denied', 'ad_storage': 'denied' });
    gtag('config', '{{ global_index.google_analytics }}');
  </script>
  {% endif %}

  <!-- Capture Mode: activa con ?capture=1 para herramientas de screenshot (VisualSitemap) -->
  <script>
    (function() {
      var p = new URLSearchParams(window.location.search);
      if (p.get('screenshot') != null || p.get('capture') === '1') {
        document.documentElement.classList.add('capture-mode');
      }
    })();
  </script>
</head>
<body class="contain {{ colorHeader }} {% if page.url == '/' %}home{% else %}seccion-interior{% endif %}">
  <!-- Google Tag Manager (noscript) -->
  {% if global_index.tag_manager %}
  <noscript><iframe title="googletagmanager" src="https://www.googletagmanager.com/ns.html?id={{ global_index.tag_manager }}" height="0"
      width="0" style="display:none;visibility:hidden"></iframe></noscript>
  {% endif %}
  {% include 'components/header.njk' %}

  <div data-scroll-container>
    {{ content | safe }}
    {% include 'onepage/footer_2.njk' %}
  </div>

  {% include 'components/cookie-banner.njk' %}


  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

  <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>
  <script type="module" src="/assets/js/index.js"></script>
  <script type="module" src="/assets/js/scroll.js"></script>
  <script type="module" src="/assets/js/inview.js"></script>
  <script src="/assets/js/cookies.js"></script>
</body>



</html>