<!-- ══ 9b · INSTAGRAM ════════════════════════════════════════════ -->
<section class="home-feature front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle smmax:reverse">
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <div class="home-ig__img">
          <img src="/assets/static/images/clinica-2.jpg" alt="Centre Dental Basté en Instagram" loading="lazy">
        </div>
      </div>
      <div class="col-xs-12 col-md-6">
        <div class="wmax-560">
          <span class="aof-eyebrow">Síguenos</span>
          <h2 class="fluid-5-l mb-16 c-accent">Estamos en Instagram</h2>
          <p class="fluid-9-r">
            Descubre casos reales, consejos de salud bucodental y las novedades de la clínica.
            Síguenos y no te pierdas nada.
          </p>
          <div class="home-cta-wrap">
            <a href="{{ global_index.social_instagram | default('#') }}" target="_blank" rel="noopener">
              <button class="btn btn-primary btn--big">Ver Instagram</button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 10 · BLOG ═════════════════════════════════════════════════ -->
<section class="home-feature front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row mb-40">
      <div class="col-xs-12 text-center">
        <span class="aof-eyebrow">Actualidad</span>
        <h2 class="fluid-5-l c-accent">Últimas novedades del blog</h2>
      </div>
    </div>
    <div class="home-blog__grid">
      {% for p in collections.post | reverse %}
      {% if loop.index <= 3 %}
      <a class="home-blog__card" href="{{ p.url }}">
        <div class="home-blog__img">
          <img src="{% if p.data.image %}/assets/static/images/blog/{{ p.data.image }}{% else %}/assets/static/images/clinica-1.jpg{% endif %}"
               alt="{{ p.data.title }}" loading="lazy">
        </div>
        <div class="home-blog__body">
          <h3 class="home-blog__title">{{ p.data.title }}</h3>
          <span class="aof-card-item__link" style="margin-top:14px;">Leer más →</span>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
    <div class="row mt-40">
      <div class="col-xs-12 text-center">
        <a href="/blog/"><button class="btn btn-primary btn--big">VER EL BLOG</button></a>
      </div>
    </div>
  </div>
</section>

<!-- ══ 11 · PREGUNTAS FRECUENTES ═════════════════════════════════ -->
<section class="aof-split bg-clear front-section" data-scroll-section>
  <div class="container-3 mx-auto">
    <div class="row mb-40">
      <div class="col-xs-12 text-center">
        <span class="aof-eyebrow">Resolvemos tus dudas</span>
        <h2 class="fluid-5-l c-accent">Preguntas frecuentes</h2>
      </div>
    </div>
    <div class="aof-faq">
      <details class="aof-faq__item" open>
        <summary class="aof-faq__q">¿Cuánto cuesta la primera visita?</summary>
        <div class="aof-faq__a">La primera visita de revisión y presupuesto cuesta 60 €, importe que se descuenta del tratamiento si lo realizas con nosotros.</div>
      </details>
      <details class="aof-faq__item">
        <summary class="aof-faq__q">¿Ofrecéis financiación?</summary>
        <div class="aof-faq__a">Sí, financiamos los tratamientos hasta en 72 meses sin intereses para que cuidar tu sonrisa sea más fácil.</div>
      </details>
      <details class="aof-faq__item">
        <summary class="aof-faq__q">¿Dónde estáis y qué horario tenéis?</summary>
        <div class="aof-faq__a">Estamos en Carrer Riera Basté, 18-20, Sant Boi de Llobregat (Barcelona). Atendemos de lunes a viernes; pide tu cita por teléfono o por el formulario.</div>
      </details>
      <details class="aof-faq__item">
        <summary class="aof-faq__q">¿Atendéis urgencias dentales?</summary>
        <div class="aof-faq__a">Sí, disponemos de atención de urgencias. Llámanos y te daremos cita lo antes posible.</div>
      </details>
    </div>
  </div>
</section>

<!-- ══ 11b · CTA FINAL CON FORMULARIO ════════════════════════════ -->
<section class="home-cta-final front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <span class="aof-eyebrow">Da el primer paso</span>
        <h2 class="fluid-4-l c-accent" style="margin:0 0 12px;">Pide tu cita en Centre Dental Basté</h2>
        <p class="fluid-9-r">Cuéntanos qué necesitas y te llamamos para resolver tus dudas sin compromiso. Primera visita de revisión y presupuesto por 60 € (a cuenta del tratamiento).</p>
      </div>
      <div class="col-xs-12 col-md-6 aof-hero__form-col">
        <div class="aof-card">
          <h3 class="fluid-7-m mb-8">Solicita información</h3>
          <p class="aof-card__subtitle mb-24">Te llamamos sin compromiso.</p>
          {% set withEmpresa = false %}
          {% set simpleLegal = true %}
          {% set formId = "contactFormCta" %}
          {% set submitClass = "btn-primary btn--full" %}
          {% set submitText  = "QUIERO INFORMACIÓN" %}
          {% include "components/contact-form.njk" %}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 12 · CONTACTO + MAPA ══════════════════════════════════════ -->
<div id="aof-contacto">
  {% include "onepage/contacta_5.njk" %}
</div>

{% include "templates/footer_3.njk" %}
