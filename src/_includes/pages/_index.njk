---
layout: layout/base.njk
colorHeader: has-light-menu
---
{% import "macros/_insert.njk" as insert %}

<style>
  /* ── Home (estructura tipo DEX, diseño Basté) ── */
  .home-feature { padding-block: 40px; }
  @media (min-width: 992px){ .home-feature { padding-block: 64px; } }
  .home-feature__img { border-radius: 20px; overflow: hidden; aspect-ratio: 4/3; background:#f3f2f0; }
  .home-feature__img img { width:100%; height:100%; object-fit: cover; display:block; }
  .home-feature .wmax-560 { max-width: 560px; }
  .home-intro { padding-block: 56px ; }
  .home-blog__grid { display:grid; grid-template-columns:1fr; gap:24px; }
  @media (min-width:600px){ .home-blog__grid{ grid-template-columns:repeat(3,1fr); } }
  .home-blog__card { display:flex; flex-direction:column; background:#fff; border:1px solid #e9e6e1; border-radius:16px; overflow:hidden; height:100%; transition:transform .3s, box-shadow .3s; color:inherit; }
  .home-blog__card:hover { transform:translateY(-4px); box-shadow:0 14px 30px rgba(0,0,0,.08); opacity:1; }
  .home-blog__img { aspect-ratio:16/10; overflow:hidden; background:#f3f2f0; }
  .home-blog__img img { width:100%; height:100%; object-fit:cover; }
  .home-blog__body { padding:22px; display:flex; flex-direction:column; flex:1; }
  .home-blog__title { font-size:17px; line-height:1.35; color:var(--c-secondary); margin:0; }
  .home-cta-wrap { margin-top: 22px; }

  /* Variante oscura (ritmo de color, como las secciones de DEX) */
  .home-feature--dark { background: var(--c-primary); }
  .home-feature--dark .aof-eyebrow { color: rgba(255,255,255,.7); }
  .home-feature--dark h2,
  .home-feature--dark h2.c-accent,
  .home-feature--dark p,
  .home-feature--dark strong { color: #fff !important; }
  .home-feature--dark .btn-primary { background:#fff !important; color: var(--c-primary) !important; }

  /* Galería de instalaciones */
  .home-gallery { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
  @media (min-width:768px){ .home-gallery{ grid-template-columns:repeat(4,1fr); } }
  .home-gallery__item { border-radius:16px; overflow:hidden; aspect-ratio:3/4; background:#f3f2f0; }
  .home-gallery__item img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s; }
  .home-gallery__item:hover img { transform:scale(1.05); }

  /* Instagram */
  .home-ig__img { border-radius:20px; overflow:hidden; aspect-ratio:1/1; }
  .home-ig__img img { width:100%; height:100%; object-fit:cover; }

  /* Equipo médico (tarjetas) */
  .home-team__intro { max-width: 760px; margin: 0 auto 44px; text-align:center; }
  .home-team__grid { display:grid; grid-template-columns:1fr; gap:26px; }
  @media (min-width:768px){ .home-team__grid{ grid-template-columns:repeat(3,1fr); } }
  .home-team__card { display:flex; flex-direction:column; background:#f5f0e8; border-radius:18px; overflow:hidden; height:100%; }
  .home-team__photo { aspect-ratio:1/1.08; overflow:hidden; background:#ece4da; }
  .home-team__photo img { width:100%; height:100%; object-fit:cover; display:block; }
  .home-team__body { padding:26px 24px 28px; display:flex; flex-direction:column; flex:1; }
  .home-team__name { font-size:20px; color:var(--c-primary); margin:0 0 10px; }
  .home-team__role { font-size:14px; color:#5a5a5a; line-height:1.6; flex:1; margin:0 0 18px; }

  /* CTA final con formulario */
  .home-cta-final { background: linear-gradient(135deg,#f3f2f0 0%, #ece4da 100%); padding-block:56px; }
  @media (min-width:992px){ .home-cta-final { padding-block:84px; } }
  .home-cta-final .aof-card { max-width:480px; }
</style>


<!-- ══ 1 · HERO ══════════════════════════════════════════════════ -->
<section class="aof-hero aof-hero--video front-section" data-scroll-section>
  <div class="aof-hero__bg">
    {% if global_index.home_video %}
    <video class="aof-hero__video" autoplay muted loop playsinline preload="auto" poster="/assets/static/images/clinica-1.jpg" aria-hidden="true">
      <source src="{{ global_index.home_video }}" type="video/mp4">
    </video>
    {% else %}
    <img src="/assets/static/images/clinica-1.jpg" alt="" aria-hidden="true">
    {% endif %}
  </div>
  <div class="container-global mx-auto">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <span class="aof-eyebrow">Sant Boi de Llobregat · Barcelona</span>
        <h1 class="fluid-3-l mb-16">Tu clínica dental de confianza</h1>
        <p class="fluid-9-r mb-24">
          Más de <strong>25 años</strong> cuidando tu sonrisa con implantología, ortodoncia
          y estética dental. Tecnología 3D, trato cercano y resultados naturales.
        </p>
        <a href="#aof-contacto" data-scroll-to>
          <button class="btn btn-primary btn--big">PIDE TU PRIMERA VISITA</button>
        </a>
      </div>
      <div class="col-xs-12 col-md-6 aof-hero__form-col">
        <div class="aof-card">
          <h2 class="fluid-7-m mb-8">Solicita información</h2>
          <p class="aof-card__subtitle mb-24">Te llamamos y resolvemos tus dudas sin compromiso.</p>
          {% set withEmpresa = false %}
          {% set simpleLegal = true %}
          {% set formId = "contactFormHero" %}
          {% set submitClass = "btn-primary btn--full" %}
          {% set submitText  = "QUIERO INFORMACIÓN" %}
          {% include "components/contact-form.njk" %}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 2 · BARRA DE CONFIANZA ════════════════════════════════════ -->
{% include "templates/trust-bar.njk" %}

<!-- ══ 3 · INTRO ═════════════════════════════════════════════════ -->
<section class="home-intro front-section pb-64" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-6 mb-16 md:mb-0">
        <span class="aof-eyebrow">Centre Dental Basté</span>
        <h2 class="fluid-4-l c-accent" style="margin:0;">Clínica dental en Sant Boi de Llobregat</h2>
      </div>
      <div class="col-xs-12 col-md-6">
        <p class="fluid-9-r">
          En Centre Dental Basté reunimos a todos los especialistas y todos los tratamientos en el
          mismo centro. Un enfoque cercano y riguroso, con la última tecnología, que prioriza tu
          comodidad y la naturalidad de los resultados.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ══ 4 · TRATAMIENTOS ══════════════════════════════════════════ -->
<section class="aof-split bg-clear front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row mb-40">
      <div class="col-xs-12 text-center">
        <span class="aof-eyebrow">Qué hacemos</span>
        <h2 class="fluid-5-l c-accent">Nuestros tratamientos</h2>
      </div>
    </div>
    <div class="aof-cards">
      {% for t in collections.tratamientos %}
      {% if t.data.seccion and loop.index <= 8 %}
      <a class="aof-card-item" href="{{ t.url }}">
        <div class="aof-card-item__img">
          <img src="{{ ('/assets/static/images' + t.data.introCta_image) if t.data.introCta_image else '/assets/static/images/clinica-1.jpg' }}"
               alt="{{ t.data.seccion | title }} en Sant Boi de Llobregat" loading="lazy">
        </div>
        <div class="aof-card-item__body">
          <h3 class="aof-card-item__title">{{ t.data.seccion | title }}</h3>
          <p class="aof-card-item__desc">{{ t.data.metaDescription | default(t.data.introtitle_subtitle) | truncate(90) }}</p>
          <span class="aof-card-item__link">Ver tratamiento →</span>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
    <div class="row mt-40">
      <div class="col-xs-12 text-center">
        <a href="/tratamientos/"><button class="btn btn-primary btn--big">VER TODOS LOS TRATAMIENTOS</button></a>
      </div>
    </div>
  </div>
</section>

<!-- ══ 5 · DESTACADO: ALL-ON-4 (imagen izq) ══════════════════════ -->
<section class="home-feature front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle smmax:reverse">
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <div class="home-feature__img">
          <img src="/assets/static/images/blog/blog-inner/implantes-dentales-1dia.jpg" alt="Implantes dentales All-on-4 en Sant Boi de Llobregat" loading="lazy">
        </div>
      </div>
      <div class="col-xs-12 col-md-6">
        <div class="wmax-560">
          <span class="aof-eyebrow">Implantología</span>
          <h2 class="fluid-5-l mb-16 c-accent">All-on-4: dientes fijos en 24-48 horas</h2>
          <p class="fluid-9-r">
            Recupera toda tu sonrisa con solo 4 o 6 implantes y carga inmediata, sin pasar meses sin
            dientes ni depender de dentaduras removibles. Cirugía guiada por ordenador y, en la mayoría
            de casos, <strong>sin injertos</strong>.
          </p>
          <div class="home-cta-wrap">
            <a href="/tratamientos/all-on-4-sant-boi-de-llobregat/"><button class="btn btn-primary btn--big">Saber más</button></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 5b · GALERÍA DE INSTALACIONES ═════════════════════════════ -->
<section class="aof-split bg-clear front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row mb-40">
      <div class="col-xs-12 text-center">
        <span class="aof-eyebrow">Nuestro centro</span>
        <h2 class="fluid-5-l c-accent">Conoce nuestras instalaciones</h2>
      </div>
    </div>
    <div class="home-gallery">
      <div class="home-gallery__item"><img src="/assets/static/images/clinica-1.jpg" alt="Instalaciones de Centre Dental Basté" loading="lazy"></div>
      <div class="home-gallery__item"><img src="/assets/static/images/clinica-2.jpg" alt="Gabinete dental en Sant Boi de Llobregat" loading="lazy"></div>
      <div class="home-gallery__item"><img src="/assets/static/images/clinica-3.jpg" alt="Clínica dental en Sant Boi de Llobregat" loading="lazy"></div>
      <div class="home-gallery__item"><img src="/assets/static/images/clinica.jpeg" alt="Recepción de Centre Dental Basté" loading="lazy"></div>
    </div>
  </div>
</section>

<!-- ══ 6 · DESTACADO: ORTODONCIA (imagen der) ════════════════════ -->
<section class="home-feature bg-clear front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle">
      <div class="col-xs-12 col-md-6">
        <div class="wmax-560">
          <span class="aof-eyebrow">Ortodoncia</span>
          <h2 class="fluid-5-l mb-16 c-accent">Ortodoncia invisible para alinear tu sonrisa</h2>
          <p class="fluid-9-r">
            Alineadores transparentes y removibles tipo Invisalign (SureSmile): cómodos, discretos y
            planificados en 3D. La forma más estética de conseguir unos dientes alineados, a cualquier edad.
          </p>
          <div class="home-cta-wrap">
            <a href="/invisalign-sant-boi-llobregat-barcelona/"><button class="btn btn-primary btn--big">Saber más</button></a>
          </div>
        </div>
      </div>
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <div class="home-feature__img">
          <img src="/assets/static/images/blog/blog-inner/ortodoncia-invisible-1024x600.jpg" alt="Ortodoncia invisible en Sant Boi de Llobregat" loading="lazy">
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 7 · RESEÑAS DE GOOGLE ═════════════════════════════════════ -->
{% include "templates/reviews.njk" %}

<!-- ══ 8 · DESTACADO: ESTÉTICA DENTAL (fondo marca) ══════════════ -->
<section class="home-feature home-feature--dark front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="row align-middle smmax:reverse">
      <div class="col-xs-12 col-md-6 mb-32 md:mb-0">
        <div class="home-feature__img">
          <img src="/assets/static/images/blog/blog-inner/estetica-dental-1024x653.jpg" alt="Estética dental y diseño de sonrisa en Sant Boi de Llobregat" loading="lazy">
        </div>
      </div>
      <div class="col-xs-12 col-md-6">
        <div class="wmax-560">
          <span class="aof-eyebrow">Estética dental</span>
          <h2 class="fluid-5-l mb-16 c-accent">Diseña tu nueva sonrisa</h2>
          <p class="fluid-9-r">
            Carillas, blanqueamiento y diseño digital de sonrisa para conseguir una sonrisa natural y
            armónica. Te enseñamos el resultado antes de empezar.
          </p>
          <div class="home-cta-wrap">
            <a href="/tratamientos/estetica-dental-sant-boi-de-llobregat/"><button class="btn btn-primary btn--big">Saber más</button></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

