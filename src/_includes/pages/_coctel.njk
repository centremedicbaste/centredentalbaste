---
layout: layout/base.njk
colorHeader: has-light-menu
---

<style>
  /* ── Landing Cóctel Medicina Estética ── */
  .coctel-hero {
    position: relative;
    min-height: 100vh;
    background-color: #1e1e1e;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .coctel-hero__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #2b2520 0%, #1e1e1e 60%, #0d0d0d 100%);
  }
  .coctel-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 40%, rgba(149,112,89,0.18) 0%, transparent 65%);
  }
  .coctel-hero__deco {
    position: absolute;
    top: 0; right: 0;
    width: 55%;
    height: 100%;
    background: linear-gradient(135deg, rgba(149,112,89,0.06) 0%, transparent 60%);
    border-left: 1px solid rgba(149,112,89,0.12);
    pointer-events: none;
  }
  .coctel-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 180px 0 80px;
  }
  .coctel-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(149,112,89,0.5);
    padding: 6px 16px;
    margin-bottom: 28px;
  }
  .coctel-badge span {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #c9a882;
    font-family: 'Lato', sans-serif;
  }
  .coctel-badge::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    background: #957059;
    transform: rotate(45deg);
    flex-shrink: 0;
  }
  .coctel-hero__eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #957059;
    margin-bottom: 16px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 7vw, 80px);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.05;
    margin-bottom: 12px;
  }
  .coctel-hero__title em {
    font-style: italic;
    color: #c9a882;
  }
  .coctel-hero__subtitle {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(18px, 3vw, 26px);
    color: rgba(255,255,255,0.6);
    margin-bottom: 40px;
  }
  .coctel-hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    margin-bottom: 64px;
  }
  .coctel-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #957059;
    color: #fff;
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.3s;
    font-family: 'Lato', sans-serif;
  }
  .coctel-btn-primary:hover { background: #7d5e4a; color: #fff; }
  .coctel-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.8);
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.3s, color 0.3s;
    font-family: 'Lato', sans-serif;
  }
  .coctel-btn-ghost:hover { border-color: #957059; color: #c9a882; }

  /* Countdown */
  .coctel-countdown {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .coctel-countdown__block {
    text-align: center;
    min-width: 64px;
  }
  .coctel-countdown__num {
    font-family: 'Playfair Display', serif;
    font-size: 40px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    display: block;
    min-width: 56px;
  }
  .coctel-countdown__label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #957059;
    margin-top: 6px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-countdown__sep {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: rgba(149,112,89,0.5);
    line-height: 1;
    padding-top: 4px;
  }

  /* ── Info cards ── */
  .coctel-info {
    background: #F8F3EF;
    padding: 80px 0;
  }
  .coctel-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: #e0d5c8;
    border: 1px solid #e0d5c8;
    margin-bottom: 0;
  }
  .coctel-card {
    background: #faf7f4;
    padding: 36px 28px;
    text-align: center;
  }
  .coctel-card__icon {
    font-size: 24px;
    margin-bottom: 12px;
    display: block;
  }
  .coctel-card__label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #957059;
    margin-bottom: 8px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-card__value {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 600;
    color: #1e1e1e;
    line-height: 1.2;
  }
  .coctel-card__sub {
    font-size: 12px;
    color: #888;
    margin-top: 4px;
    font-family: 'Lato', sans-serif;
  }

  /* ── Notice ── */
  .coctel-notice {
    background: #1e1e1e;
    padding: 20px 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .coctel-notice__icon {
    font-size: 20px;
    flex-shrink: 0;
  }
  .coctel-notice__text {
    flex: 1;
  }
  .coctel-notice__title {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #957059;
    font-weight: 700;
    font-family: 'Lato', sans-serif;
  }
  .coctel-notice__sub {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    margin-top: 3px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-notice__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #957059;
    color: #fff;
    padding: 12px 24px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.3s;
    white-space: nowrap;
    font-family: 'Lato', sans-serif;
  }
  .coctel-notice__btn:hover { background: #7d5e4a; color: #fff; }

  /* ── Servicios ── */
  .coctel-servicios {
    padding: 100px 0;
    background: #ffffff;
  }
  .coctel-section-label {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #957059;
    margin-bottom: 16px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700;
    color: #1e1e1e;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .coctel-section-title em {
    font-style: italic;
    color: #957059;
  }
  .coctel-section-desc {
    font-size: 16px;
    color: #666;
    line-height: 1.7;
    max-width: 560px;
    font-family: 'Lato', sans-serif;
  }
  .coctel-service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 56px;
  }
  .coctel-service-item {
    border: 1px solid #e8ddd4;
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .coctel-service-item:hover {
    border-color: #957059;
    transform: translateY(-4px);
  }
  .coctel-service-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: #957059;
    transition: height 0.4s;
  }
  .coctel-service-item:hover::before { height: 100%; }
  .coctel-service-num {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    color: rgba(149,112,89,0.15);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 16px;
  }
  .coctel-service-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 600;
    color: #1e1e1e;
    margin-bottom: 12px;
  }
  .coctel-service-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
    font-family: 'Lato', sans-serif;
  }
  .coctel-service-tag {
    display: inline-block;
    background: #F8F3EF;
    border: 1px solid #e0d5c8;
    padding: 4px 12px;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #957059;
    margin-top: 16px;
    font-family: 'Lato', sans-serif;
  }

  /* ── How it works ── */
  .coctel-how {
    padding: 100px 0;
    background: #1e1e1e;
  }
  .coctel-how .coctel-section-title { color: #ffffff; }
  .coctel-how .coctel-section-desc { color: rgba(255,255,255,0.55); }
  .coctel-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0;
    margin-top: 56px;
    border: 1px solid #2e2e2e;
  }
  .coctel-step {
    padding: 40px 32px;
    border-right: 1px solid #2e2e2e;
    position: relative;
  }
  .coctel-step:last-child { border-right: none; }
  .coctel-step__num {
    font-family: 'Playfair Display', serif;
    font-size: 56px;
    color: rgba(149,112,89,0.2);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 20px;
  }
  .coctel-step__title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 10px;
  }
  .coctel-step__desc {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    font-family: 'Lato', sans-serif;
  }
  .coctel-step__accent {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, #957059, transparent);
  }

  /* ── CTA final ── */
  .coctel-cta-final {
    padding: 100px 0;
    background: #F8F3EF;
    text-align: center;
  }
  .coctel-cta-final .coctel-section-title {
    margin-bottom: 12px;
  }
  .coctel-cta-final .coctel-section-desc {
    margin: 0 auto 40px;
    text-align: center;
  }
  .coctel-cta-group-center {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    align-items: center;
  }
  .coctel-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #25D366;
    color: #fff;
    padding: 18px 40px;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.3s;
    font-family: 'Lato', sans-serif;
  }
  .coctel-wa-btn:hover { background: #1ebe58; color: #fff; }
  .coctel-wa-btn svg { width: 22px; height: 22px; fill: #fff; flex-shrink: 0; }

  .coctel-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 48px 0 32px;
  }
  .coctel-divider hr { flex: 1; border: none; border-top: 1px solid #e0d5c8; }
  .coctel-divider span {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #957059;
    font-family: 'Lato', sans-serif;
  }

  /* Map embed */
  .coctel-map {
    width: 100%;
    height: 320px;
    border: 0;
    filter: grayscale(30%);
  }

  @media (max-width: 768px) {
    .coctel-hero__title { font-size: 38px; }
    .coctel-steps { grid-template-columns: 1fr; }
    .coctel-step { border-right: none; border-bottom: 1px solid #2e2e2e; }
    .coctel-step:last-child { border-bottom: none; }
    .coctel-notice { flex-direction: column; text-align: center; }
    .coctel-notice__btn { width: 100%; justify-content: center; }
  }
</style>


