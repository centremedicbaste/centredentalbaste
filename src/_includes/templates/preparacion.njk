<!-- preparacion.njk -->
<!-- preparacion.njk — Pasos previos a la intervención (tarjetas con icono).
     Se incluye solo si la ficha define  preparacion: true  -->
{% if preparacion %}
<section class="aof-prep aof-split front-section" data-scroll-section>
  <div class="container-global mx-auto">
    <div class="aof-prep__title-wrap">
      <span class="aof-eyebrow">Antes de empezar</span>
      <h2 class="fluid-5-l c-accent">{{ preparacion_title | default('Pasos a seguir antes de la intervención') }}</h2>
    </div>
    <div class="aof-prep__grid">

      <div class="aof-prep__card">
        <span class="aof-prep__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M12 9.5v4M10 11.5h4"/></svg>
        </span>
        <span class="aof-prep__name">Historial médico</span>
        <p class="aof-prep__desc">Revisamos tus antecedentes, alergias y la medicación que tomas para garantizar la máxima seguridad.</p>
      </div>

      <div class="aof-prep__card">
        <span class="aof-prep__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/></svg>
        </span>
        <span class="aof-prep__name">Estudio radiográfico 3D</span>
        <p class="aof-prep__desc">Realizamos un escáner para planificar el tratamiento con precisión milimétrica.</p>
      </div>

      <div class="aof-prep__card">
        <span class="aof-prep__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8M8 12.5h5"/></svg>
        </span>
        <span class="aof-prep__name">Plan de tratamiento</span>
        <p class="aof-prep__desc">Te explicamos cada paso del procedimiento y resolvemos todas tus dudas sin compromiso.</p>
      </div>

      <div class="aof-prep__card">
        <span class="aof-prep__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M15.5 9.4a3.5 3.5 0 1 0 0 5.2M8 11.3h5.5M8 13.3h5.5"/></svg>
        </span>
        <span class="aof-prep__name">Presupuesto y financiación</span>
        <p class="aof-prep__desc">Recibes un presupuesto claro y sin sorpresas, con opciones de financiación a tu medida.</p>
      </div>

    </div>
  </div>
</section>
{% endif %}
