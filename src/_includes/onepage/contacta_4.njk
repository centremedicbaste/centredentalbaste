<!-- contacta_4.njk — Envoltorio visual con título centrado. Usa el partial compartido. -->
<div id="contacta_4" class="front-section" data-scroll data-scroll-section>
    <section class="container-global-3 mx-auto">
        <div class="row">
            <div class="col-xs-12 text-center ptr-120 pbr-120">
                <div class="text-18-r mb-24 c-accent">{{global_index.contacta_4_title}}</div>
                <div class="fluid-4-l">{{global_index.contacta_4_subtitle}}</div>
            </div>
        </div>

        {% set withEmpresa  = true %}
        {% set submitClass  = "btn-primary btn--full" %}
        {% set submitText   = global_index.banner_button %}
        {% set modalBg      = "#ffffff" %}

        {% include "components/contact-form.njk" %}

    </section>
</div>
